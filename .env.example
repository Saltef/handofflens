OPENROUTER_API_KEY=
COHERE_API_KEY=

# Cohere Command A+ is called directly through Cohere because it is not exposed
# as a structured-output model on OpenRouter in this workflow.
# The frozen routed comparison uses the IDs in eval/experiment_manifest.json.
EVAL_MODELS=cohere-aplus:command-a-plus-05-2026,anthropic/claude-haiku-4.5
# EVAL_MODELS overrides frozen defaults only when EXPERIMENT_MODE=exploratory.
EXPERIMENT_MODE=confirmatory
JUDGE_MODEL=openai/gpt-5-mini
JUDGE_MAX_TOKENS=5000
# The cohere-aplus prefix selects JSON Schema with strict-tool fallback.
COHERE_SCHEMA_MODE=json-schema
COHERE_TEMPERATURE=0
COHERE_VALIDATION_RETRIES=1
OPENROUTER_VALIDATION_RETRIES=1
# Optional Cohere tuning knobs for small stability tests:
# COHERE_THINKING_BUDGET=1000
# COHERE_TOOL_CHOICE=REQUIRED

OPENROUTER_SITE_URL=https://github.com/YOUR_USERNAME/handofflens
OPENROUTER_APP_NAME=HandoffLens Eval
OPENROUTER_TIMEOUT_MS=120000
OPENROUTER_MAX_TOKENS=20000
OPENROUTER_RETRIES=0
COHERE_TIMEOUT_MS=120000
COHERE_RETRIES=0
