{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClinicalChangeExtraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "patient_context",
    "medication_changes",
    "diagnosis_changes",
    "procedures_and_tests",
    "labs",
    "follow_up_actions",
    "safety_flags",
    "uncertain_items",
    "handoff_atoms",
    "two_page_summary"
  ],
  "properties": {
    "case_id": { "type": "string" },
    "patient_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["age", "gender", "admission_diagnosis"],
      "properties": {
        "age": { "type": "string" },
        "gender": { "type": "string" },
        "admission_diagnosis": { "type": "string" }
      }
    },
    "medication_changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started", "stopped", "changed", "continued", "uncertain"],
      "properties": {
        "started": { "$ref": "#/$defs/evidenceList" },
        "stopped": { "$ref": "#/$defs/evidenceList" },
        "changed": { "$ref": "#/$defs/evidenceList" },
        "continued": { "$ref": "#/$defs/evidenceList" },
        "uncertain": { "$ref": "#/$defs/evidenceList" }
      }
    },
    "diagnosis_changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["admission", "discharge", "new_or_changed"],
      "properties": {
        "admission": { "type": "string" },
        "discharge": { "$ref": "#/$defs/evidenceList" },
        "new_or_changed": { "$ref": "#/$defs/evidenceList" }
      }
    },
    "procedures_and_tests": { "$ref": "#/$defs/evidenceList" },
    "labs": { "$ref": "#/$defs/evidenceList" },
    "follow_up_actions": { "$ref": "#/$defs/evidenceList" },
    "safety_flags": { "$ref": "#/$defs/safetyFlagList" },
    "uncertain_items": { "$ref": "#/$defs/evidenceList" },
    "handoff_atoms": { "$ref": "#/$defs/handoffAtomList" },
    "two_page_summary": { "type": "string" }
  },
  "$defs": {
    "evidenceList": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceItem" }
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "rationale", "source_quote"],
      "properties": {
        "label": { "type": "string" },
        "rationale": { "type": "string" },
        "source_quote": { "type": "string" }
      }
    },
    "safetyFlagList": {
      "type": "array",
      "items": { "$ref": "#/$defs/safetyFlagItem" }
    },
    "safetyFlagItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "rationale", "source_quote", "safety_type"],
      "properties": {
        "label": { "type": "string" },
        "rationale": { "type": "string" },
        "source_quote": { "type": "string" },
        "safety_type": {
          "type": "string",
          "enum": [
            "return_precaution",
            "monitoring_instruction",
            "medication_safety",
            "pending_or_critical_result",
            "source_stated_risk"
          ]
        }
      }
    },
    "handoffAtomList": {
      "type": "array",
      "items": { "$ref": "#/$defs/handoffAtom" }
    },
    "handoffAtom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atom_id",
        "label",
        "atom_type",
        "instruction_kind",
        "safety_type",
        "action",
        "target",
        "time_window",
        "threshold",
        "owner",
        "derived_views",
        "rationale",
        "source_quote"
      ],
      "properties": {
        "atom_id": { "type": "string" },
        "label": { "type": "string" },
        "atom_type": {
          "type": "string",
          "enum": [
            "medication_change",
            "diagnosis",
            "procedure_or_test",
            "lab_result",
            "follow_up_instruction",
            "uncertainty"
          ]
        },
        "instruction_kind": {
          "type": "string",
          "enum": [
            "none",
            "appointment",
            "lab_monitoring",
            "self_monitoring",
            "return_precaution",
            "medication_safety",
            "pending_result",
            "source_stated_risk"
          ]
        },
        "safety_type": {
          "type": "string",
          "enum": [
            "none",
            "return_precaution",
            "monitoring_instruction",
            "medication_safety",
            "pending_or_critical_result",
            "source_stated_risk"
          ]
        },
        "action": { "type": "string" },
        "target": { "type": "string" },
        "time_window": { "type": "string" },
        "threshold": { "type": "string" },
        "owner": { "type": "string" },
        "derived_views": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "medication_changes.started",
              "medication_changes.stopped",
              "medication_changes.changed",
              "medication_changes.continued",
              "medication_changes.uncertain",
              "diagnosis_changes.discharge",
              "diagnosis_changes.new_or_changed",
              "procedures_and_tests",
              "labs",
              "follow_up_actions",
              "safety_flags",
              "uncertain_items"
            ]
          }
        },
        "rationale": { "type": "string" },
        "source_quote": { "type": "string" }
      }
    }
  }
}
