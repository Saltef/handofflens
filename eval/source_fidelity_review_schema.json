{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceFidelityReview",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviewer_id", "case_id", "model_slot", "claim_reviews", "omissions", "global_review"],
  "properties": {
    "reviewer_id": { "type": "string" },
    "case_id": { "type": "string" },
    "model_slot": { "enum": ["Model A", "Model B"] },
    "claim_reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "factual_support", "relationship_support", "error_scope", "corrected_text", "reviewer_note"],
        "properties": {
          "claim_id": { "type": "string" },
          "factual_support": { "enum": ["", "supported", "partially_supported", "unsupported", "not_assessable"] },
          "relationship_support": { "enum": ["", "supported", "partially_supported", "unsupported", "not_applicable", "not_assessable"] },
          "error_scope": { "enum": ["", "none", "formatting_only", "semantic_error", "not_assessable"] },
          "corrected_text": { "type": "string" },
          "reviewer_note": { "type": "string" }
        }
      }
    },
    "omissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["domain", "status", "target_explicitness", "description", "source_quote"],
        "properties": {
          "domain": { "enum": ["medication", "diagnosis", "procedure_or_test", "lab", "follow_up", "safety", "other"] },
          "status": { "enum": ["", "none", "present", "not_assessable"] },
          "target_explicitness": { "enum": ["", "explicit_in_source", "not_explicit", "not_assessable"] },
          "description": { "type": "string" },
          "source_quote": { "type": "string" }
        }
      }
    },
    "global_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary_fidelity", "structured_output_completeness", "review_minutes", "overall_comment"],
      "properties": {
        "summary_fidelity": { "enum": ["", "fully_supported", "contains_semantic_error", "not_assessable"] },
        "structured_output_completeness": { "enum": ["", "complete_for_explicit_targets", "explicit_target_missing", "not_assessable"] },
        "review_minutes": { "type": ["number", "null"], "minimum": 0 },
        "overall_comment": { "type": "string" }
      }
    }
  }
}
